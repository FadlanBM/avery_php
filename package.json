{
  "name": "php-native-app",
  "version": "1.0.0",
  "description": "PHP native app with Tailwind CSS",
  "scripts": {
    "build": "tailwindcss -c ./tailwind.config.js -i ./resources/css/input.css -o ./assets/css/tailwind.css --minify",
    "watch": "tailwindcss -c ./tailwind.config.js -i ./resources/css/input.css -o ./assets/css/tailwind.css --watch",
    "vercel-build": "npm run build && mkdir -p public && cp -r assets public/assets"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "qrcode": "^1.5.4",
    "tailwindcss": "^3.4.1"
  }
}
